{
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "cd backend && ./gradlew build -x test",
    "watchPatterns": [
      "backend/**"
    ]
  },
  "deploy": {
    "startCommand": "cd backend && java -jar build/libs/santa-rita-dashboard-service-0.0.1-SNAPSHOT.jar",
    "healthcheckPath": "/actuator/health",
    "healthcheckTimeout": 100
  }
}
